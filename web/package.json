{
  "name": "syncwave-web",
  "version": "1.0.0",
  "description": "Cross-platform audio streaming via web browser",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "install-deps": "npm install && cd frontend && npm install",
    "build-frontend": "cd frontend && npm run build",
    "dev-full": "concurrently \"npm run dev\" \"cd frontend && npm start\"",
    "prod": "npm run build-frontend && npm start"
  },
  "keywords": [
    "audio",
    "streaming",
    "multiroom",
    "web",
    "browser"
  ],
  "author": "SyncWave",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
